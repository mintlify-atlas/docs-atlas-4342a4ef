  "keyFeatures": [
    "Advanced moderation with auto-mod filters",
    "Gamification system with levels and rewards",
    "Music playback with queue management",
    "Custom role management and auto-roles",
    "Server logs and audit trails",
    "User profiles with coins and XP",
    "Polls, giveaways, and games",
    "AI chat integration (OpenAI, Gemini, Claude)",
    "Game stats tracking for multiple games",
    "Twitch live stream notifications",
    "Custom triggers and auto-responses",
    "Voice sessions and channel automation",
    "Select role menus and self-assignable roles",
    "Starboard for popular messages",
    "Multi-language support"
  ],
  "publicApiSurface": [
    "/about - Bot information and getting started",
    "/config - Server configuration commands",
    "/warn - Warn users and add infractions",
    "/role - Role management commands",
    "/channel - Channel management commands",
    "/music - Music playback commands",
    "/poll - Create and manage polls",
    "/giveaway - Run giveaways",
    "/games - Interactive games (8ball, flip, roll, rps, russian-roulette)",
    "/chat - AI-powered chat",
    "/profile - User profile and stats",
    "/leaderboard - Server rankings",
    "/search - Web, Wikipedia, weather, game info",
    "/gamestats - Game statistics for various games",
    "/translate - Language translation",
    "/status - Bot and Discord status"
  ]
